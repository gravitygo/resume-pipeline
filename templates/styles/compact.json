{
  "body": {
    "fontFamily": "Arial, Helvetica, sans-serif",
    "fontSize": "9pt",
    "lineHeight": "1.3",
    "color": "#333333"
  },
  "h1": {
    "fontSize": "16pt",
    "fontWeight": "700",
    "color": "#111111",
    "marginBottom": "4px"
  },
  "h2": {
    "fontSize": "10pt",
    "fontWeight": "600",
    "color": "#444444",
    "borderBottom": "1px solid #cccccc",
    "marginTop": "10px",
    "marginBottom": "4px",
    "paddingBottom": "2px",
    "textTransform": "uppercase"
  },
  "h3": {
    "fontSize": "9pt",
    "fontWeight": "600",
    "color": "#222222",
    "marginTop": "6px",
    "marginBottom": "2px"
  },
  "p": {
    "fontSize": "9pt",
    "lineHeight": "1.3",
    "marginBottom": "4px",
    "color": "#333333"
  },
  "ul": {
    "marginLeft": "14px",
    "marginBottom": "4px"
  },
  "li": {
    "marginBottom": "2px",
    "fontSize": "9pt",
    "lineHeight": "1.2"
  }
}

